/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    make_lastz_chains modules configuration
    Per-process resource requirements and ext.args overrides.
    Separated config per major pipeline step.
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

/*
 * HOW PER-PROCESS ENVIRONMENTS WORK
 * ───────────────────────────────────
 * Each withName block can declare BOTH a `conda` path AND a `container` path.
 * Nextflow uses whichever one matches the active profile:
 *   -profile conda      → uses the `conda` directive
 *   -profile apptainer  → uses the `container` directive
 *
 * You can mix profiles per-run (e.g. one step uses conda, another uses apptainer)
 * by setting different values in the blocks below.
 *
 * You can also combine environment type with executor:
 *   -profile apptainer,slurm
 */

process {

    // ── Publish directory defaults ──────────────────────────────────────────
    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].toLowerCase()}" },
        mode: params.publish_dir_mode,
        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
    ]

    // ════════════════════════════════════════════════════════════════════════
    // STEP 0: Genome preparation
    // ════════════════════════════════════════════════════════════════════════

    withName: 'FA_TO_TWO_BIT' {
        label     = 'process_single'
        conda     = '/path/to/your/conda/env'           // ← replace
        container = '/path/to/your/ucscGenomeBrowser.sif' // ← replace
        publishDir = [
            path: { "${params.outdir}/genome_prep" },
            mode: params.publish_dir_mode,
            pattern: "*.2bit"
        ]
    }

    withName: 'TWO_BIT_INFO' {
        label     = 'process_single'
        conda     = '/path/to/your/conda/env'
        container = '/path/to/your/ucscGenomeBrowser.sif'
        publishDir = [
            path: { "${params.outdir}/genome_prep" },
            mode: params.publish_dir_mode,
            pattern: "*.chrom.sizes"
        ]
    }

    // ════════════════════════════════════════════════════════════════════════
    // STEP 1: Partition
    // ════════════════════════════════════════════════════════════════════════

    withName: 'PARTITION' {
        label     = 'process_single'
        conda     = '/path/to/your/conda/env'
        container = '/path/to/your/ucscGenomeBrowser.sif'
        publishDir = [
            path: { "${params.outdir}/partition" },
            mode: params.publish_dir_mode,
            pattern: "*_partitions.txt"
        ]
    }

    // ════════════════════════════════════════════════════════════════════════
    // STEP 2: LASTZ alignment
    // ════════════════════════════════════════════════════════════════════════

    withName: 'LASTZ' {
        label     = 'process_single'
        conda     = '/path/to/your/conda/env'
        container = '/path/to/your/ucscGenomeBrowser.sif'
        // Override memory/time here if LASTZ jobs routinely need more:
        // memory = { 32.GB * task.attempt }
        errorStrategy = 'retry'
        maxRetries    = 3
        publishDir    = [ enabled: false ]
    }

    // ════════════════════════════════════════════════════════════════════════
    // STEP 3: PSL concatenation (cat step)
    // ════════════════════════════════════════════════════════════════════════

    withName: 'CAT_PSL' {
        label     = 'process_single'
        conda     = '/path/to/your/conda/env'
        container = '/path/to/your/ucscGenomeBrowser.sif'
        publishDir = [ enabled: false ]
    }

    // ════════════════════════════════════════════════════════════════════════
    // STEP 4: Chain building (sort → bundle → axtChain → merge)
    // ════════════════════════════════════════════════════════════════════════

    withName: 'PSL_SORT_ACC' {
        label     = 'process_medium'
        conda     = '/path/to/your/conda/env'
        container = '/path/to/your/ucscGenomeBrowser.sif'
        publishDir = [ enabled: false ]
    }

    withName: 'PSL_BUNDLE' {
        label     = 'process_single'
        conda     = '/path/to/your/conda/env'
        container = '/path/to/your/ucscGenomeBrowser.sif'
        publishDir = [ enabled: false ]
    }

    withName: 'AXT_CHAIN' {
        label     = 'process_medium'
        conda     = '/path/to/your/conda/env'
        container = '/path/to/your/ucscGenomeBrowser.sif'
        errorStrategy = 'retry'
        maxRetries    = 3
        publishDir    = [ enabled: false ]
    }

    withName: 'CHAIN_MERGE_SORT' {
        label     = 'process_medium'
        conda     = '/path/to/your/conda/env'
        container = '/path/to/your/ucscGenomeBrowser.sif'
        publishDir = [
            path: { "${params.outdir}/chain_merge" },
            mode: params.publish_dir_mode,
            pattern: "*.all.chain.gz"
        ]
    }

    // ════════════════════════════════════════════════════════════════════════
    // STEP 5: Fill chains (optional)
    // ════════════════════════════════════════════════════════════════════════

    withName: 'FILL_CHAIN_SPLIT' {
        label     = 'process_medium'
        conda     = '/path/to/your/conda/env'
        container = '/path/to/your/ucscGenomeBrowser.sif'
        publishDir = [ enabled: false ]
    }

    withName: 'REPEAT_FILLER' {
        label     = 'process_single'
        conda     = '/path/to/your/conda/env'
        container = '/path/to/your/ucscGenomeBrowser.sif'
        memory        = { (params.fill_memory as int).GB * task.attempt }
        errorStrategy = 'retry'
        maxRetries    = 3
        publishDir    = [ enabled: false ]
    }

    withName: 'FILL_CHAIN_MERGE' {
        label     = 'process_medium'
        conda     = '/path/to/your/conda/env'
        container = '/path/to/your/ucscGenomeBrowser.sif'
        publishDir = [
            path: { "${params.outdir}/fill_chains" },
            mode: params.publish_dir_mode,
            pattern: "*.filled.chain.gz"
        ]
    }

    // ════════════════════════════════════════════════════════════════════════
    // STEP 6: Clean chains (optional)
    // ════════════════════════════════════════════════════════════════════════

    withName: 'CHAIN_CLEANER' {
        label     = 'process_high'
        conda     = '/path/to/your/conda/env'
        container = '/path/to/your/ucscGenomeBrowser.sif'
        memory = { (params.chain_clean_memory as int).GB * task.attempt }
        publishDir = [ enabled: false ]
    }

    withName: 'CHAIN_FILTER' {
        label     = 'process_single'
        conda     = '/path/to/your/conda/env'
        container = '/path/to/your/ucscGenomeBrowser.sif'
        publishDir = [
            path: { "${params.outdir}/final" },
            mode: params.publish_dir_mode,
            pattern: "*.final.chain.gz"
        ]
    }
}
