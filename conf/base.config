/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    make_lastz_chains base configuration
    Defines process resource labels used across the pipeline.
    Actual per-process resource assignments are in conf/modules.config.
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

process {
    // Default error strategy for all processes
    errorStrategy = { task.exitStatus in ((130..145) + 104) ? 'retry' : 'finish' }
    maxRetries    = 1
    maxErrors     = '-1'

    // Resource labels — assign one to each process via `label`
    withLabel: 'process_single' {
        cpus   = 1
        memory = { 16.GB * task.attempt }
        time   = { 48.h  * task.attempt }
    }
    withLabel: 'process_medium' {
        cpus   = 1
        memory = { 50.GB * task.attempt }
        time   = { 48.h  * task.attempt }
    }
    withLabel: 'process_high' {
        cpus   = 1
        memory = { 100.GB * task.attempt }
        time   = { 48.h   * task.attempt }
    }
    withLabel: 'process_long' {
        cpus   = 1
        memory = { 16.GB * task.attempt }
        time   = { 120.h * task.attempt }
    }
}
