/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    make_lastz_chains — single unified Nextflow configuration

    Infrastructure configuration — do not edit for normal runs.
    Scientific parameters (genome paths, alignment settings) live in params.json.

    Usage:
      nextflow run main.nf -params-file params.json -profile apptainer,slurm

    This file contains:
      1. params {}          — output dir, resource ceilings, nf-core boilerplate
      2. Process resources  — compute tiers (cpus, memory, time) via withLabel
      3. Per-step config    — container, conda, publishDir via withName
      4. Profiles           — executor and environment selection
      5. Reporting          — timeline, trace, DAG
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

nextflow.enable.dsl = 2

cleanup = false
workDir = 'work'

manifest {
    name            = 'make_lastz_chains'
    author          = 'Bogdan M. Kirilenko, Alejandro Gonzales-Irribarren, Nil Tianchen Mu, Virag Sharma, Ekaterina Osipova, Michael Hiller'
    homePage        = 'https://github.com/hillerlab/make_lastz_chains'
    description     = 'Pipeline to create chain-formatted pairwise genome alignments.'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=25.04.6'
    version         = '3.1.3'
}

validation {
    help {
        enabled = true
        command = "nextflow run main.nf -profile <docker/singularity/.../institute>"
        fullParameter = "help_full"
        showHiddenParameter = "show_hidden"
    }
}

// ══════════════════════════════════════════════════════════════════════════════
// SECTION 1 — Infrastructure parameters
// Edit this section only to change compute limits or output behaviour.
// Scientific parameters live in params.json.
// ══════════════════════════════════════════════════════════════════════════════

params {

    // ── Output ──────────────────────────────────────────────────────────────
    outdir           = './results'
    publish_dir_mode = 'copy'

    // ── Debug ───────────────────────────────────────────────────────────────
    // Force faToTwoBit -long (always v1 .2bit). Used to exercise the v1 path
    // on small genomes for parity testing — leave false in production.
    force_long_2bit  = false

    // ── nf-core boilerplate ──────────────────────────────────────────────────
    validate_params  = true
    help             = false
    version          = false
    monochrome_logs  = false
    email            = null
    email_on_fail    = null
}

// ══════════════════════════════════════════════════════════════════════════════
// SECTION 2 — Compute resource tiers  (withLabel)
//
// All pipeline tools are single-threaded, so cpus is fixed at 1.
// Memory and time scale with task.attempt.
//
// SLURM partition routing (slurm profile):
//   All current labels (0.5 h – 3 h) → htc partition (public QOS)
//   Jobs > 4 h → public partition (public QOS)
// ══════════════════════════════════════════════════════════════════════════════

process {
    shell    = ['/bin/bash', '-euo', 'pipefail']

    // Conda is disabled by default — use -profile apptainer (or conda to re-enable)
    conda.enabled = false

    // Retry up to maxRetries times, then terminate the workflow. Using a
    // dynamic errorStrategy (rather than maxErrors = 1) so a permanent task
    // failure ALWAYS aborts — `maxErrors = -1` previously masked silent data
    // loss (e.g. the BULK filename-too-long bug).
    errorStrategy = { task.exitStatus in ((130..145) + 104 + 175) ? 'retry' : 'finish' }
    maxRetries    = 8

    // Short-lived steps + LASTZ chunks (conversion, partition, LASTZ, cat, bundle, filter)
    withLabel: 'process_fast' {
        cpus   = 1
        memory = { 24.GB * task.attempt }
        time   = { 0.5.h * task.attempt }
    }
    // Medium steps: PSL sorting, axtChain, chainMergeSort, fill chain merge
    withLabel: 'process_medium' {
        cpus   = 1
        memory = { 50.GB * task.attempt }
        time   = { 2.h   * task.attempt }
    }

    // GPU
    withLabel: process_gpu {
        ext.use_gpu = { workflow.profile.contains('gpu') }
        accelerator = { workflow.profile.contains('gpu') ? 1 : null }
    }

// ══════════════════════════════════════════════════════════════════════════════
// SECTION 3 — Per-step configuration  (withName)
// Each block sets resources (if not using a label), container image, conda env,
// and whether outputs are published to results/.
// ══════════════════════════════════════════════════════════════════════════════

    // ── STEP 0: Genome preparation ──────────────────────────────────────────

    withName: '.*:FA_TO_TWO_BIT' {
        cpus      = 1
        memory    = { 60.GB * task.attempt }
        time      = { 0.5.h * task.attempt }
        conda     = "${projectDir}/environment.yml"
        
        publishDir = [
            path: { "${params.outdir}/00_genome_prep" },
            mode: params.publish_dir_mode,
            pattern: "*.2bit"
        ]
    }

    withName: '.*:CHROMSIZE' {
        label     = 'process_fast'
        conda     = "${projectDir}/environment.yml"
        
        publishDir = [
            path: { "${params.outdir}/00_genome_prep" },
            mode: params.publish_dir_mode,
            pattern: "*/*chrom.sizes"
        ]
    }

    withName: '.*:EXTRACT_CHROMS' {
        // For v1 .2bit genomes EXTRACT_CHROMS runs `twoBitToFa` once per chrom
        // sequentially (extraction is fast per chrom but accumulates), so it
        // can need more than the 0.5 h `process_fast` ceiling on big genomes.
        cpus      = 1
        memory    = { 24.GB * task.attempt }
        time      = { 2.h   * task.attempt }
        conda     = "${projectDir}/environment.yml"
        // Not published — these per-chrom FASTAs are intermediate and large;
        // they only need to live in the work dir to be symlinked into LASTZ tasks.
    }

    // ── STEP 1: Partition ───────────────────────────────────────────────────

    withName: '.*:PARTITION_REFERENCE|.*:PARTITION_QUERY' {
        label     = 'process_fast'
        conda     = "${projectDir}/environment.yml"
        publishDir = [
            path: { "${params.outdir}/01_partition" },
            mode: params.publish_dir_mode,
            pattern: "*_partitions.txt"
        ]
    }

    // ── STEP 2: LASTZ alignment ─────────────────────────────────────────────

    withName: '.*:LASTZ' {
        label        = 'process_fast'
        array        = 500
        beforeScript = 'sleep $((RANDOM % 60))'    // stagger starts to avoid slurm prolog storm
        publishDir   = [
            path: { "${params.outdir}/02_lastz_psl" },
            mode: 'symlink',
            pattern: '*.psl'
        ]
    }

    // ── STEP 3: PSL concatenation ───────────────────────────────────────────

    withName: '.*:CAT_PSL' {
        label     = 'process_fast'
        conda     = "${projectDir}/environment.yml"
        publishDir = [
            path: { "${params.outdir}/03_concat_lastz_output" },
            mode: 'symlink',
            pattern: '*.psl.gz'
        ]
    }

    // ── STEP 4: Chain building (sort → bundle → axtChain → merge) ──────────

    withName: '.*:PSL_SORT_ACC' {
        label     = 'process_medium'
        publishDir = [ enabled: false ]
    }

    withName: '.*:PSL_BUNDLE' {
        label     = 'process_fast'
        publishDir = [ enabled: false ]
    }

    withName: '.*:AXT_CHAIN' {
        label     = 'process_medium'
        conda     = "${projectDir}/environment.yml"
        array     = 500
        publishDir = [
            path: { "${params.outdir}/04_axtchain" },
            mode: 'symlink',
            pattern: '*.chain'
        ]
    }

    withName: '.*:CHAINTOOLS_ANTIREPEAT' {
        label     = 'process_medium'
        conda     = "${projectDir}/environment.yml"
        publishDir = [
            path: { "${params.outdir}/04_axtchain/chain_antirepeat" },
            mode: 'symlink',
            pattern: '*.chain'
        ]
    }

    withName: '.*:CHAINTOOLS_MERGE' {
        label     = 'process_medium'
        publishDir = [ enabled: false ]
    }

    withName: '.*:CHAINTOOLS_SORT_MERGED_FILLED_CHAINS' {
        label     = 'process_medium'
        publishDir = [
            path: { "${params.outdir}/04_axtchain/merged_chains" },
            mode: params.publish_dir_mode,
            pattern: "*.chain*"
        ]
    }

    // ── STEP 5: Fill chains (optional) ─────────────────────────────────────

    withName: '.*:CHAINTOOLS_SPLIT' {
        label     = 'process_fast'
        publishDir = [ enabled: false ]
    }

    withName: '.*:REPEAT_FILLER' {
        cpus      = 1
        memory    = { 24.GB * task.attempt }
        time      = { 1.h   * task.attempt }
        array     = 500
        publishDir = [ enabled: false ]
    }

    withName: '.*:CHAINTOOLS_MERGE_FILLED_CHAINS' {
        label     = 'process_medium'
        publishDir = [
            path: { "${params.outdir}/05_filled_chains" },
            mode: params.publish_dir_mode,
            pattern: "*.chain.gz"
        ]
    }

    // ── STEP 6: Clean chains (optional) ────────────────────────────────────

    withName: '.*:CHAIN_CLEANER' {
        cpus      = 1
        memory    = { 80.GB * task.attempt }
        time      = { 3.h   * task.attempt }
        conda     = "${projectDir}/environment.yml"
        publishDir = [
            path: { "${params.outdir}/06_cleaned_chains" },
            mode: 'symlink',
        ]
    }

    withName: '.*:CHAINTOOLS_FILTER_CLEANED_CHAINS' {
        label     = 'process_fast'
        ext.prefix = { "${params.reference_name}.${params.query_name}.allfilled" }
        publishDir = [
            path: { "${params.outdir}/07_final" },
            mode: params.publish_dir_mode,
            pattern: "*chain.gz"
        ]
    }
}

// ══════════════════════════════════════════════════════════════════════════════
// SECTION 4 — Profiles
// Combine an executor profile with an environment profile, e.g.:
//   -profile apptainer,slurm
// ══════════════════════════════════════════════════════════════════════════════

profiles {

    local {
        process.executor = 'local'
    }

    // ── SLURM (your HPC cluster) ────────────────────────────────────────────
    // Partition is selected automatically based on requested wall time:
    //   <= 4 h → htc    (public QOS, max 52 CPU / 185 GB per node)
    //   >  4 h → public (public QOS, max 28 CPU / 248 GB per node)
    // process_fast (0.5 h) + process_single (1 h) + process_medium (2 h) + process_high (3 h) → htc
    slurm {
        process.executor       = 'slurm'
        process.queue          = { task.time <= 24.h ? 'batch' : 'long' }
        process.clusterOptions = '--qos=public --signal=USR2@180 --export=ALL,SLURM_SKIP_EPILOG=1'
        process.stageInMode    = 'symlink'
        executor {
            queueSize         = 10000
            killBatchSize     = 1000000
            pollInterval      = '10 s'      // internal task-monitor tick (no SLURM RPC)
            queueStatInterval = '1 min'     // squeue cadence — halves RPC pressure
            submitRateLimit   = '100/1min'
            exitReadTimeout   = '5 min'    // tolerate slow .exitcode propagation; lets retry fire on ghosts
        }
    }

    debug {
        dumpHashes              = true
        process.beforeScript    = 'echo $HOSTNAME'
        cleanup                 = false
        nextflow.enable.configProcessNamesValidation = true
    }

    conda {
        conda.enabled           = true
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        conda.channels          = ['conda-forge', 'bioconda']
        apptainer.enabled       = false
    }

    mamba {
        conda.enabled           = true
        conda.useMamba          = true
        conda.channels          = ['conda-forge', 'bioconda']
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
    }

    docker {
        docker.enabled          = true
        conda.enabled           = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
        docker.runOptions       = '-u $(id -u):$(id -g)'
    }

    arm {
        docker.runOptions       = '-u $(id -u):$(id -g) --platform=linux/amd64'
        includeConfig 'conf/arm.config'
    }

    singularity {
        singularity.enabled     = true
        singularity.autoMounts  = true
        conda.enabled           = false
        docker.enabled          = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
    }

    podman {
        podman.enabled          = true
        conda.enabled           = false
        docker.enabled          = false
        singularity.enabled     = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
    }

    shifter {
        shifter.enabled         = true
        conda.enabled           = false
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
    }

    charliecloud {
        charliecloud.enabled    = true
        conda.enabled           = false
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        apptainer.enabled       = false
    }

    apptainer {
        apptainer.enabled       = true
        apptainer.autoMounts    = true
        conda.enabled           = false
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        apptainer.pullTimeout   = '60 min'
    }

    wave {
        apptainer.ociAutoPull   = true
        singularity.ociAutoPull = true
        wave.enabled            = true
        wave.freeze             = true
        wave.strategy           = 'conda,container'
    }

    gitpod {
        executor.name           = 'local'
        executor.cpus           = 4
        executor.memory         = 8.GB
        process {
            resourceLimits = [
                memory: 8.GB,
                cpus  : 4,
                time  : 1.h
            ]
        }
    }

    gpu {
        docker.runOptions       = '-u $(id -u):$(id -g) --gpus all'
        apptainer.runOptions    = '--nv'
        singularity.runOptions  = '--nv'
    }

    test {
        params.reference_name   = 'test_ref'
        params.query_name       = 'test_query'
        params.reference_genome = "${projectDir}/test_data/test_reference.fa"
        params.query_genome     = "${projectDir}/test_data/test_query.fa"
        params.chain_linear_gap = 'loose'
        params.outdir           = 'test_results'
        params.use_container    = true

        params.skip_fill_chains = false
        params.skip_fill_unmask = false
        params.skip_clean_chain = false

        params.seq1_chunk    = 10000000
        params.seq2_chunk    = 10000000
        params.seq1_lap      = 0
        params.seq2_lap      = 10000 
        params.lastz_y       = 9400
        params.lastz_h       = 2000
        params.lastz_l       = 3000
        params.lastz_k       = 2400
        params.lastz_q       = null
        params.min_chain_score = 1000
        params.chain_linear_gap = 'loose'
        params.bundle_psl_max_bases = 1000000
        params.num_fill_jobs = 1000
        params.fill_insert_chain_min_score = 5000
        params.fill_gap_max_size_t = 20000
        params.fill_gap_max_size_q = 20000
        params.fill_gap_min_size_t = 30
        params.fill_gap_min_size_q = 30
        params.fill_lastz_k = 2000
        params.fill_lastz_l = 3000
        params.chain_clean_memory = 100
        params.clean_chain_parameters = '-LRfoldThreshold=2.5 -doPairs -LRfoldThresholdPairs=10 -maxPairDistance=10000 -maxSuspectScore=100000 -minBrokenChainScore=75000'
     }
}

// ══════════════════════════════════════════════════════════════════════════════
// SECTION 5 — Container image
// Set the container image to use for all processes through use_container option.
// If not set, the default is to use the apptainer cache image for every module.
// To modify go to params.json and set 'use_container' to false.
// ══════════════════════════════════════════════════════════════════════════════

if (params.use_container) {
  process {
    withName: '.*' {
        container = System.getenv('NXF_CONTAINER_IMAGE') ?:
            'ghcr.io/hillerlab/make_lastz_chains:latest'
    }
  }
}

// ══════════════════════════════════════════════════════════════════════════════
// SECTION 6 — Execution reporting
// ══════════════════════════════════════════════════════════════════════════════

def trace_timestamp = new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')

timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_timeline_${trace_timestamp}.html"
}

report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_report_${trace_timestamp}.html"
}

trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_trace_${trace_timestamp}.txt"
}

dag {
    enabled = true
    file    = "${params.outdir}/pipeline_info/pipeline_dag_${trace_timestamp}.html"
}

// ══════════════════════════════════════════════════════════════════════════════
// SECTION 7 — Environment configuration
// ══════════════════════════════════════════════════════════════════════════════

/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    ENVIRONMENT CONFIG
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

// Export these variables to prevent local Python/R libraries from conflicting with those in the container
// The JULIA depot path has been adjusted to a fixed path `/usr/local/share/julia` that needs to be used for packages in the container.
// See https://apeltzer.github.io/post/03-julia-lang-nextflow/ for details on that. Once we have a common agreement on where to keep Julia packages, this is adjustable.

env {
    PYTHONNOUSERSITE = 1
    R_PROFILE_USER   = "/.Rprofile"
    R_ENVIRON_USER   = "/.Renviron"
    JULIA_DEPOT_PATH = "/usr/local/share/julia"
}

/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    REGISTRY CONFIG
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

// Set default registry for Apptainer, Docker, Podman, Charliecloud and Singularity independent of -profile
// Will not be used unless Apptainer / Docker / Podman / Charliecloud / Singularity are enabled
// Set to your registry if you have a mirror of containers
apptainer.registry    = 'quay.io'
docker.registry       = 'quay.io'
podman.registry       = 'quay.io'
singularity.registry  = 'quay.io'
charliecloud.registry = 'quay.io'
