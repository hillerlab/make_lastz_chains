/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    make_lastz_chains — single unified Nextflow configuration

    This file contains everything in one place:
      1. params {}          — scientific / I/O parameters (edit these for your run)
      2. Process resources  — compute tiers (cpus, memory, time) via withLabel
      3. Per-step config    — container, conda, publishDir via withName
      4. Profiles           — executor and environment selection
      5. Reporting          — timeline, trace, DAG

    To pass parameters from a JSON file instead of the command line:
      nextflow run main.nf -params-file my_params.json
      (replaces the old --params_from_file flag from make_chains.py)

    Container image: docker://nilablueshirt/make_lastz_chains:latest-amd64
    Build locally: docker buildx build --platform linux/amd64 -t nilablueshirt/make_lastz_chains:latest-amd64 .
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

nextflow.enable.dsl = 2

manifest {
    name            = 'make_lastz_chains'
    author          = 'Bogdan M. Kirilenko, Michael Hiller, Virag Sharma, Ekaterina Osipova, Nil Tianchen Mu'
    homePage        = 'https://github.com/hillerlab/make_lastz_chains'
    description     = 'Pipeline to create chain-formatted pairwise genome alignments.'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=23.10.0'
    version         = '3.0.0'
}

// ── Resource ceiling helper ────────────────────────────────────────────────
// Caps memory and time requests against params.max_memory / params.max_time
// so no job exceeds the partition hard limits.
def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else return obj
        } catch (all) { return obj }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else return obj
        } catch (all) { return obj }
    } else if (type == 'cpus') {
        try { return Math.min(obj as int, params.max_cpus as int) }
        catch (all) { return obj }
    }
}

// ══════════════════════════════════════════════════════════════════════════════
// SECTION 1 — Pipeline parameters
// ══════════════════════════════════════════════════════════════════════════════

params {

    // ── Input / Output ──────────────────────────────────────────────────────
    target_name      = null      // e.g. 'hg38'
    query_name       = null      // e.g. 'mm39'
    target_genome    = null      // path to target genome (FASTA or .2bit)
    query_genome     = null      // path to query genome (FASTA or .2bit)
    outdir           = './results'
    publish_dir_mode = 'copy'

    // ── Checkpoint entry point inputs ───────────────────────────────────────
    // Used with -entry FROM_FILL_CHAINS or -entry FROM_CLEAN_CHAINS.
    // These point to published intermediate files from a previous full run.
    merged_chain        = null   // -entry FROM_FILL_CHAINS: path to *.all.chain.gz
    filled_chain        = null   // -entry FROM_CLEAN_CHAINS: path to *.filled.chain.gz
    target_twobit       = null   // required for both entry aliases
    query_twobit        = null   // required for both entry aliases
    target_chrom_sizes  = null   // required for both entry aliases
    query_chrom_sizes   = null   // required for both entry aliases

    // ── Genome partitioning ─────────────────────────────────────────────────
    seq1_chunk = 175000000  // target chunk size (bp)
    seq2_chunk = 50000000   // query chunk size (bp)
    seq1_lap   = 0          // target chunk overlap (bp)
    seq2_lap   = 10000      // query chunk overlap (bp)
    // Note: seq1_limit / seq2_limit (min sequence length filter) were accepted
    // by the old make_chains.py CLI but were never applied in either pipeline.

    // ── LASTZ alignment ─────────────────────────────────────────────────────
    lastz_y = 9400    // gap extension penalty
    lastz_h = 2000    // seed hit count
    lastz_l = 3000    // step length
    lastz_k = 2400    // minimum score for anchor alignments
    lastz_q = null    // optional substitution score matrix file

    // ── Chain building ──────────────────────────────────────────────────────
    min_chain_score      = 1000     // minimum chain score (axtChain -minScore)
    chain_linear_gap     = 'loose'  // linearGap model: 'loose' or 'medium'
    bundle_psl_max_bases = 1000000  // max bases per PSL bundle

    // ── Fill chains (optional step) ─────────────────────────────────────────
    skip_fill_chains            = false
    skip_fill_unmask            = false
    num_fill_jobs               = 1000
    fill_insert_chain_min_score = 5000
    fill_gap_max_size_t         = 20000
    fill_gap_max_size_q         = 20000
    fill_gap_min_size_t         = 30
    fill_gap_min_size_q         = 30
    fill_lastz_k                = 2000
    fill_lastz_l                = 3000

    // ── Clean chains (optional step) ────────────────────────────────────────
    skip_clean_chain       = false
    clean_chain_parameters = '-LRfoldThreshold=2.5 -doPairs -LRfoldThresholdPairs=10 -maxPairDistance=10000 -maxSuspectScore=100000 -minBrokenChainScore=75000'

    // ── Execution / cluster ─────────────────────────────────────────────────
    cluster_executor = 'local'
    cluster_queue    = 'batch'
    job_time_req     = '48h'

    // ── Tool paths (override if not in PATH) ────────────────────────────────
    lastz_path      = 'lastz'
    axt_to_psl_path = 'axtToPsl'

    // ── nf-core boilerplate ──────────────────────────────────────────────────
    validate_params        = true
    show_hidden_params     = false
    help                   = false
    version                = false
    monochrome_logs        = false
    hook_url               = null
    email                  = null
    email_on_fail          = null
    plaintext_email        = false
    max_multiqc_email_size = '25.MB'

    // ── Resource ceilings (enforced by check_max() in withLabel blocks) ─────
    // Set to the hard limits of the most generous partition you use.
    // Jobs requesting more will be silently capped to these values.
    //
    // Your HPC partitions:
    //   htc    (<  4 h, public QOS): max 52 CPU / 185 GB per node
    //   public (>= 4 h, public QOS): max 28 CPU / 248 GB per node
    //
    // Ceiling is set to the public partition limit. process_fast jobs only
    // ever request 16 GB so they are always safely under the 185 GB htc limit.
    max_memory = '248.GB'
    max_cpus   = 52
    max_time   = '240.h'
}

// ══════════════════════════════════════════════════════════════════════════════
// SECTION 2 — Compute resource tiers  (withLabel)
//
// All pipeline tools are single-threaded, so cpus is fixed at 1.
// Memory and time scale with task.attempt and are capped by check_max().
//
// Two time categories drive automatic SLURM partition selection (slurm profile):
//   process_fast   requests 2 h  → htc partition    (public QOS)
//   all others     request  48 h+ → public partition (public QOS)
// ══════════════════════════════════════════════════════════════════════════════

process {
    executor = params.cluster_executor != 'local' ? params.cluster_executor : 'local'
    shell    = ['/bin/bash', '-euo', 'pipefail']

    // Conda is disabled by default — use -profile apptainer (or conda to re-enable)
    conda.enabled = false

    // Default error strategy: retry on OOM/signal errors, fail otherwise
    errorStrategy = { task.exitStatus in ((130..145) + 104) ? 'retry' : 'finish' }
    maxRetries    = 1
    maxErrors     = '-1'

    // Short-lived steps (file conversion, partitioning, bundling, filtering)
    // → routes to htc partition via the slurm profile's dynamic queue rule
    withLabel: 'process_fast' {
        cpus   = 1
        memory = { check_max(16.GB * task.attempt, 'memory') }
        time   = { check_max(2.h   * task.attempt, 'time')   }
    }
    // Single-CPU steps that may run for many hours (LASTZ chunks, repeat filler)
    withLabel: 'process_single' {
        cpus   = 1
        memory = { check_max(16.GB  * task.attempt, 'memory') }
        time   = { check_max(48.h   * task.attempt, 'time')   }
    }
    // Medium steps: PSL sorting, axtChain, chainMergeSort, fill chain merge
    withLabel: 'process_medium' {
        cpus   = 1
        memory = { check_max(50.GB  * task.attempt, 'memory') }
        time   = { check_max(48.h   * task.attempt, 'time')   }
    }
    // High-memory step: chainCleaner
    withLabel: 'process_high' {
        cpus   = 1
        memory = { check_max(100.GB * task.attempt, 'memory') }
        time   = { check_max(48.h   * task.attempt, 'time')   }
    }
    // Extended wall time for steps that may exceed 48 h
    withLabel: 'process_long' {
        cpus   = 1
        memory = { check_max(16.GB  * task.attempt, 'memory') }
        time   = { check_max(120.h  * task.attempt, 'time')   }
    }

// ══════════════════════════════════════════════════════════════════════════════
// SECTION 3 — Per-step configuration  (withName)
// Each block sets the resource label, container image, conda env, and whether
// outputs are published to results/. Only final/key intermediates are published.
//
// Container: build the Dockerfile and push to a registry, then replace
//   docker://nilablueshirt/make_lastz_chains:latest-amd64
// Conda:     the environment.yml at the project root is used automatically.
// ══════════════════════════════════════════════════════════════════════════════

    // ── STEP 0: Genome preparation ──────────────────────────────────────────

    withName: 'FA_TO_TWO_BIT' {
        label     = 'process_fast'
        conda     = "${projectDir}/environment.yml"
        container = 'docker://nilablueshirt/make_lastz_chains:latest-amd64'
        publishDir = [
            path: { "${params.outdir}/genome_prep" },
            mode: params.publish_dir_mode,
            pattern: "*.2bit"
        ]
    }

    withName: 'TWO_BIT_INFO' {
        label     = 'process_fast'
        conda     = "${projectDir}/environment.yml"
        container = 'docker://nilablueshirt/make_lastz_chains:latest-amd64'
        publishDir = [
            path: { "${params.outdir}/genome_prep" },
            mode: params.publish_dir_mode,
            pattern: "*.chrom.sizes"
        ]
    }

    // ── STEP 1: Partition ───────────────────────────────────────────────────

    withName: 'PARTITION' {
        label     = 'process_fast'
        conda     = "${projectDir}/environment.yml"
        container = 'docker://nilablueshirt/make_lastz_chains:latest-amd64'
        publishDir = [
            path: { "${params.outdir}/partition" },
            mode: params.publish_dir_mode,
            pattern: "*_partitions.txt"
        ]
    }

    // ── STEP 2: LASTZ alignment ─────────────────────────────────────────────

    withName: 'LASTZ' {
        label         = 'process_single'   // single-threaded, up to 48 h per chunk
        conda         = "${projectDir}/environment.yml"
        container     = 'docker://nilablueshirt/make_lastz_chains:latest-amd64'
        array         = 500                // submit as SLURM job arrays (max 500 per array)
        errorStrategy = 'retry'
        maxRetries    = 3
        publishDir    = [ enabled: false ]
        // Override memory if chunks require more, e.g.:
        // memory = { check_max(32.GB * task.attempt, 'memory') }
    }

    // ── STEP 3: PSL concatenation ───────────────────────────────────────────

    withName: 'CAT_PSL' {
        label     = 'process_fast'
        conda     = "${projectDir}/environment.yml"
        container = 'docker://nilablueshirt/make_lastz_chains:latest-amd64'
        publishDir = [ enabled: false ]
    }

    // ── STEP 4: Chain building (sort → bundle → axtChain → merge) ──────────

    withName: 'PSL_SORT_ACC' {
        label     = 'process_medium'
        conda     = "${projectDir}/environment.yml"
        container = 'docker://nilablueshirt/make_lastz_chains:latest-amd64'
        publishDir = [ enabled: false ]
    }

    withName: 'PSL_BUNDLE' {
        label     = 'process_fast'
        conda     = "${projectDir}/environment.yml"
        container = 'docker://nilablueshirt/make_lastz_chains:latest-amd64'
        publishDir = [ enabled: false ]
    }

    withName: 'AXT_CHAIN' {
        label         = 'process_medium'   // 50 GB x attempt; override below if needed
        conda         = "${projectDir}/environment.yml"
        container     = 'docker://nilablueshirt/make_lastz_chains:latest-amd64'
        array         = 100                // submit as SLURM job arrays (max 100 per array)
        errorStrategy = 'retry'
        maxRetries    = 3
        publishDir    = [ enabled: false ]
        // Override memory for very large genomes, e.g.:
        // memory = { check_max(100.GB * task.attempt, 'memory') }
    }

    withName: 'CHAIN_MERGE_SORT' {
        label     = 'process_medium'
        conda     = "${projectDir}/environment.yml"
        container = 'docker://nilablueshirt/make_lastz_chains:latest-amd64'
        publishDir = [
            path: { "${params.outdir}/chain_merge" },
            mode: params.publish_dir_mode,
            pattern: "*.all.chain.gz"
        ]
    }

    // ── STEP 5: Fill chains (optional) ─────────────────────────────────────

    withName: 'FILL_CHAIN_SPLIT' {
        label     = 'process_fast'
        conda     = "${projectDir}/environment.yml"
        container = 'docker://nilablueshirt/make_lastz_chains:latest-amd64'
        publishDir = [ enabled: false ]
    }

    withName: 'REPEAT_FILLER' {
        label         = 'process_single'   // per-chunk gap filling, single-threaded, up to 48 h
        conda         = "${projectDir}/environment.yml"
        container     = 'docker://nilablueshirt/make_lastz_chains:latest-amd64'
        array         = 500                // submit as SLURM job arrays (max 500 per array)
        errorStrategy = 'retry'
        maxRetries    = 3
        publishDir    = [ enabled: false ]
    }

    withName: 'FILL_CHAIN_MERGE' {
        label     = 'process_medium'
        conda     = "${projectDir}/environment.yml"
        container = 'docker://nilablueshirt/make_lastz_chains:latest-amd64'
        publishDir = [
            path: { "${params.outdir}/fill_chains" },
            mode: params.publish_dir_mode,
            pattern: "*.filled.chain.gz"
        ]
    }

    // ── STEP 6: Clean chains (optional) ────────────────────────────────────

    withName: 'CHAIN_CLEANER' {
        label     = 'process_high'   // 100 GB x attempt; single high-memory job
        conda     = "${projectDir}/environment.yml"
        container = 'docker://nilablueshirt/make_lastz_chains:latest-amd64'
        publishDir = [ enabled: false ]
    }

    withName: 'CHAIN_FILTER' {
        label     = 'process_fast'
        conda     = "${projectDir}/environment.yml"
        container = 'docker://nilablueshirt/make_lastz_chains:latest-amd64'
        publishDir = [
            path: { "${params.outdir}/final" },
            mode: params.publish_dir_mode,
            pattern: "*.final.chain.gz"
        ]
    }
}

// ══════════════════════════════════════════════════════════════════════════════
// SECTION 4 — Profiles
// Combine an executor profile with an environment profile, e.g.:
//   -profile apptainer,slurm
// ══════════════════════════════════════════════════════════════════════════════

profiles {

    local {
        process.executor = 'local'
    }

    // ── SLURM (your HPC cluster) ────────────────────────────────────────────
    // Partition is selected automatically based on requested wall time:
    //   < 4 h  → htc    (public QOS, max 52 CPU / 185 GB per node)
    //   >= 4 h → public (public QOS, max 28 CPU / 248 GB per node)
    // process_fast steps request 2 h → htc
    // All other labels request 48 h+ → public
    slurm {
        process.executor       = 'slurm'
        process.queue          = { task.time < 4.h ? 'htc' : 'public' }
        process.clusterOptions = '--qos=public'
        executor {
            queueSize       = 1000
            submitRateLimit = '10/1min'
        }
    }

    sge {
        process.executor = 'sge'
        process.queue    = params.cluster_queue
    }

    conda {
        conda.enabled       = true
        docker.enabled      = false
        singularity.enabled = false
        apptainer.enabled   = false
    }

    apptainer {
        apptainer.enabled    = true
        apptainer.autoMounts = true
        docker.enabled       = false
        singularity.enabled  = false
        conda.enabled        = false
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
        apptainer.enabled      = false
        conda.enabled          = false
    }

    docker {
        docker.enabled      = true
        singularity.enabled = false
        apptainer.enabled   = false
        conda.enabled       = false
    }

    test {
        params.target_name   = 'test_ref'
        params.query_name    = 'test_query'
        params.target_genome = "${projectDir}/test_data/test_reference.fa"
        params.query_genome  = "${projectDir}/test_data/test_query.fa"
        params.outdir        = 'test_results'
        params.seq1_chunk    = 10000000
        params.seq2_chunk    = 10000000
    }
}

// ══════════════════════════════════════════════════════════════════════════════
// SECTION 5 — Execution reporting
// ══════════════════════════════════════════════════════════════════════════════

def trace_timestamp = new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')

timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_timeline_${trace_timestamp}.html"
}

report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_report_${trace_timestamp}.html"
}

trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_trace_${trace_timestamp}.txt"
}

dag {
    enabled = true
    file    = "${params.outdir}/pipeline_info/pipeline_dag_${trace_timestamp}.html"
}

// ── Global environment ─────────────────────────────────────────────────────
env {
    PYTHONNOUSERSITE = 1
    R_PROFILE_USER   = "/.Rprofile"
    R_ENVIRON_USER   = "/.Renviron"
    JULIA_DEPOT_PATH = "/usr/local/share/julia"
}
